# Environment Variables for TrustScore AI
# Copy this file to .env and fill in your API key

# ── LLM Provider (choose one) ──
# Options: "groq", "openai", "mock"
# Use "mock" by default so local demos do not send uploaded document text
# to an external LLM unless you explicitly opt in.
USE_PROVIDER=mock

# Comma-separated browser origins allowed to call the API.
# Set this to your deployed frontend origin in production.
TRUSTSCORE_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional LLM reliability controls.
LLM_TIMEOUT=12
LLM_MAX_RETRIES=2
LLM_FAILURE_COOLDOWN=60

# ── Groq API Key (free at https://console.groq.com) ──
# GROQ_API_KEY=your_groq_api_key_here

# ── OpenAI API Key (alternative) ──
# OPENAI_API_KEY=your_openai_api_key_here
